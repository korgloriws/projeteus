{
  "name": "projeteus",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "vite --host --force",
    "dev:api": "tsx watch --tsconfig tsconfig.server.json server/index.ts",
    "build": "npm run build:web && npm run build:api",
    "build:web": "vite build",
    "build:api": "node ./build.mjs",
    "start:api": "node --import dotenv/config --enable-source-maps ./server/dist/index.mjs",
    "codegen": "orval --config ./orval.config.ts",
    "db:push": "tsx --tsconfig tsconfig.server.json ./db/push.ts",
    "db:seed": "tsx --tsconfig tsconfig.server.json ./db/src/seed.ts",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
