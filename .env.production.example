# Copie este arquivo para ".env" na VPS e ajuste os valores:
#   cp .env.production.example .env

NODE_ENV=production
PORT=8080

# Banco SQLite (arquivo dentro do volume persistente /app/data)
DATABASE_URL=file:./data/projeteus.db

# Segredo da sessão — OBRIGATÓRIO trocar por um valor aleatório longo.
# Gere um com:  openssl rand -hex 32
SESSION_SECRET=troque-por-um-segredo-aleatorio-bem-longo

# Origem pública da aplicação (usada pelo CORS).
WEB_ORIGIN=https://srv1176791.hstgr.cloud

# Admin inicial — criado ao rodar o seed manualmente:
#   docker compose exec app npm run db:seed
SEED_ADMIN_EMAIL=mateus@projeteus.local
SEED_ADMIN_NAME=Mateus
SEED_ADMIN_PASSWORD=troque-esta-senha
